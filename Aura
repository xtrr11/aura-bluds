    changeKeyBtn.Position = UDim2.new(0.04,0,0,390)
    changeKeyBtn.Text = "Change Spider Key"
    changeKeyBtn.BackgroundColor3 = Color3.fromRGB(50,50,50)
    changeKeyBtn.TextColor3 = Color3.new(1,1,1)
    changeKeyBtn.TextSize = 12

    local listening = false
    changeKeyBtn.MouseButton1Click:Connect(function()
        listening = true
        changeKeyBtn.Text = "Press any key..."
    end)

    UIS.InputBegan:Connect(function(i, gp)
        if listening and not gp then
            CurrentSpiderKey = i.KeyCode
            spiderKeyLabel.Text = "Spider Key: " .. CurrentSpiderKey.Name
            changeKeyBtn.Text = "Change Spider Key"
            listening = false
        end
    end)

    CombatTab.MouseButton1Click:Connect(function()
        CombatFrame.Visible = true
        RagebotFrame.Visible = false
        VisualsFrame.Visible = false
        ExploitsFrame.Visible = false
        CombatTab.TextColor3 = Color3.fromRGB(255, 80, 120)
        RagebotTab.TextColor3 = Color3.fromRGB(255, 255, 255)
        VisualsTab.TextColor3 = Color3.fromRGB(255, 255, 255)
        ExploitsTab.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)

    RagebotTab.MouseButton1Click:Connect(function()
        CombatFrame.Visible = false
        RagebotFrame.Visible = true
        VisualsFrame.Visible = false
        ExploitsFrame.Visible = false
        CombatTab.TextColor3 = Color3.fromRGB(255, 255, 255)
        RagebotTab.TextColor3 = Color3.fromRGB(255, 80, 120)
        VisualsTab.TextColor3 = Color3.fromRGB(255, 255, 255)
        ExploitsTab.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)

    VisualsTab.MouseButton1Click:Connect(function()
        CombatFrame.Visible = false
        RagebotFrame.Visible = false
        VisualsFrame.Visible = true
        ExploitsFrame.Visible = false
        CombatTab.TextColor3 = Color3.fromRGB(255, 255, 255)
        RagebotTab.TextColor3 = Color3.fromRGB(255, 255, 255)
