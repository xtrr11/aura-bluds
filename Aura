    local function ShowInventory(plr)
        if not plr or not plr.Character then 
            InvFrame.Visible = false 
            return 
        end
        local char = plr.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local dist = root and math.floor((Cam.CFrame.Position - root.Position).Magnitude) or 0
        PlayerNameLabel.Text = "Viewing: " .. plr.Name .. " [" .. dist .. "m]"

        local character = plr.Character
        local backpack = plr:FindFirstChild("Backpack")

        local armorItems = {}
        if character then
            for _, item in ipairs(character:GetChildren()) do
                if item:IsA("Accessory") or string.find(item.Name:lower(), "helmet") or string.find(item.Name:lower(), "vest") or string.find(item.Name:lower(), "armor") then
                    table.insert(armorItems, "• " .. item.Name)
                end
            end
        end
        ArmorList.Text = #armorItems > 0 and table.concat(armorItems, "\n") or "No Armor"

        local hotbarItems = {}
        if character then
            for _, item in ipairs(character:GetChildren()) do
                if item:IsA("Tool") then
                    table.insert(hotbarItems, "• " .. item.Name)
                end
            end
        end
        HotbarList.Text = #hotbarItems > 0 and table.concat(hotbarItems, "\n") or "Empty"

        local fullItems = {}
        if backpack then
            for _, item in ipairs(backpack:GetChildren()) do
                if item:IsA("Tool") or item:IsA("HopperBin") then
                    table.insert(fullItems, "• " .. item.Name)
                end
            end
        end
        FullList.Text = #fullItems > 0 and table.concat(fullItems, "\n") or "Empty"

        InvFrame.Visible = true
    end

