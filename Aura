                    data.Name.Text = plr.Name .. " ["..dist.."m]"
                    data.Name.Position = Vector2.new(rPos.X, hPos.Y - height*0.48)
                    data.Name.Color = color
                    data.Name.Visible = Settings.ESP.Names

                    local gunText = "No Gun"
                    if char:FindFirstChildWhichIsA("Tool") then
                        gunText = char:FindFirstChildWhichIsA("Tool").Name
                    end

                    if Settings.ESP.GunHolder then
                        data.GunHolder.Text = "Holding: " .. gunText
                        data.GunHolder.Position = Vector2.new(rPos.X, rPos.Y + height*0.65)
                        data.GunHolder.Visible = true
                    else
                        data.GunHolder.Visible = false
                    end

                    if Settings.ESP.Caution then
                        local lookingAtYou = false
                        if char:FindFirstChild("Head") then
                            local headDir = (Cam.CFrame.Position - char.Head.Position).Unit
                            local playerLookDir = char.Head.CFrame.LookVector
                            if headDir:Dot(playerLookDir) > 0.75 then
                                lookingAtYou = true
                            end
                        end
                        data.Caution.Text = "CAUTION"
                        data.Caution.Position = Vector2.new(rPos.X, hPos.Y - height*0.88)
                        data.Caution.Visible = lookingAtYou
                    else
                        data.Caution.Visible = false
                    end

                    if Settings.ESP.HealthBar then
                        local health = char.Humanoid.Health / char.Humanoid.MaxHealth
                        data.HealthBar.Size = Vector2.new(4, height * health)
                        data.HealthBar.Position = Vector2.new(data.Box.Position.X - 6, data.Box.Position.Y + height * (1 - health))
                        data.HealthBar.Color = Color3.fromRGB(255 - (255 * health), 255 * health, 0)
                        data.HealthBar.Visible = true
                    else
                        data.HealthBar.Visible = false
                    end

                    if Settings.ESP.Tracers then
                        data.Tracer.From = Vector2.new(Cam.ViewportSize.X/2, Cam.ViewportSize.Y)
                        data.Tracer.To = Vector2.new(rPos.X, rPos.Y)
                        data.Tracer.Color = color
                        data.Tracer.Visible = true
                    else
                        data.Tracer.Visible = false
                    end
                else
                    data.Box.Visible = false
                    data.Name.Visible = false
                    data.Caution.Visible = false
                    data.GunHolder.Visible = false
                    data.HealthBar.Visible = false
                    data.Tracer.Visible = false
                end
            else
                data.Box.Visible = false
                data.Name.Visible = false
                data.Caution.Visible = false
                data.GunHolder.Visible = false
                data.HealthBar.Visible = false
                data.Tracer.Visible = false
            end
        end

