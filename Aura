    local function AddToggle(parent, y, text, default, callback)
        local btn = Instance.new("TextButton", parent)
        btn.Size = UDim2.new(0.92,0,0,32)
        btn.Position = UDim2.new(0.04,0,0,y)
        btn.BackgroundColor3 = default and Color3.fromRGB(255, 80, 120) or Color3.fromRGB(35,35,35)
        btn.Text = text
        btn.TextColor3 = Color3.new(1,1,1)
        btn.TextSize = 12
        btn.Font = Enum.Font.Gotham
        btn.MouseButton1Click:Connect(function()
            default = not default
            btn.BackgroundColor3 = default and Color3.fromRGB(255, 80, 120) or Color3.fromRGB(35,35,35)
            callback(default)
        end)
    end

    local function AddSlider(parent, y, text, min, max, default, callback, step)
        step = step or 5
        local label = Instance.new("TextLabel", parent)
        label.Size = UDim2.new(0.92,0,0,22)
        label.Position = UDim2.new(0.04,0,0,y)
        label.BackgroundTransparency = 1
        label.Text = text .. ": " .. default
        label.TextColor3 = Color3.new(1,1,1)
        label.TextSize = 12
        label.Font = Enum.Font.Gotham

        local minus = Instance.new("TextButton", parent)
        minus.Size = UDim2.new(0.2,0,0,28)
        minus.Position = UDim2.new(0.04,0,0,y+25)
        minus.Text = "-"
        minus.BackgroundColor3 = Color3.fromRGB(50,50,50)
        minus.TextColor3 = Color3.new(1,1,1)
        minus.MouseButton1Click:Connect(function()
            default = math.clamp(default - step, min, max)
            label.Text = text .. ": " .. default
            callback(default)
        end)

        local plus = Instance.new("TextButton", parent)
        plus.Size = UDim2.new(0.2,0,0,28)
        plus.Position = UDim2.new(0.75,0,0,y+25)
        plus.Text = "+"
        plus.BackgroundColor3 = Color3.fromRGB(50,50,50)
        plus.TextColor3 = Color3.new(1,1,1)
        plus.MouseButton1Click:Connect(function()
            default = math.clamp(default + step, min, max)
            label.Text = text .. ": " .. default
            callback(default)
        end)
    end

