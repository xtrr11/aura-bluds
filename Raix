local function IsVisible(target)
    if not Settings.Aimbot.VisibilityCheck then return true end
    local origin = Cam.CFrame.Position
    local direction = (target.Position - origin).Unit * (target.Position - origin).Magnitude
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LP.Character, Cam}
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.IgnoreWater = true
    local result = Workspace:Raycast(origin, direction, params)
    return not result or result.Instance:FindFirstAncestor(target.Parent.Name) or result.Instance == target
end

