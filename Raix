local function CreateToggle(parent, y, text, default, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0.92,0,0,36)
    btn.Position = UDim2.new(0.04,0,0,y)
    btn.BackgroundColor3 = default and Color3.fromRGB(255,60,100) or Color3.fromRGB(45,45,45)
    btn.Text = "   "..text.."   "..(default and "ON" or "OFF")
    btn.TextColor3 = Color3.new(1,1,1)
    btn.TextSize = 13
    btn.Font = Enum.Font.Gotham
    btn.MouseButton1Click:Connect(function()
        default = not default
        btn.BackgroundColor3 = default and Color3.fromRGB(255,60,100) or Color3.fromRGB(45,45,45)
        btn.Text = "   "..text.."   "..(default and "ON" or "OFF")
        callback(default)
    end)
end

