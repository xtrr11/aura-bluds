local function SaveOriginalLighting()
    OriginalLighting.Brightness = Lighting.Brightness
    OriginalLighting.ClockTime = Lighting.ClockTime
    OriginalLighting.FogEnd = Lighting.FogEnd
    OriginalLighting.GlobalShadows = Lighting.GlobalShadows
    OriginalLighting.Ambient = Lighting.Ambient
end
local function ToggleFullBright(enable)
    if enable then
        if not OriginalLighting.Brightness then SaveOriginalLighting() end
        Lighting.Brightness = 3
        Lighting.ClockTime = 14
        Lighting.FogEnd = 100000
        Lighting.GlobalShadows = false
        Lighting.Ambient = Color3.fromRGB(255, 255, 255)
        Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
    else
        if OriginalLighting.Brightness then
            Lighting.Brightness = OriginalLighting.Brightness
            Lighting.ClockTime = OriginalLighting.ClockTime
            Lighting.FogEnd = OriginalLighting.FogEnd
            Lighting.GlobalShadows = OriginalLighting.GlobalShadows
            Lighting.Ambient = OriginalLighting.Ambient
        end
    end
end
local function FindNPCFolder()
    if NPCFolderCache and NPCFolderCache.Parent then return NPCFolderCache end
    for _, v in pairs(workspace:GetDescendants()) do
        if (v.Name == "NPCs" or v.Name:find("Scav")) and (v:IsA("Folder") or v:IsA("Model")) then
            NPCFolderCache = v
            return v
        end
    end
    return nil
end
local function FindLootFolder()
    local buildings = workspace:FindFirstChild("Buildings")
    if buildings then return buildings:FindFirstChild("Loots") end
    return workspace:FindFirstChild("Loots")
end
local function CreateESP(table, obj, color, isLoot, playerName)
    if table[obj] then return end
    local Box = Drawing.new("Square") Box.Thickness = 2 Box.Filled = false Box.Visible = false
    local Name = Drawing.new("Text") Name.Size = 13 Name.Center = true Name.Outline = true Name.Visible = false
    local HealthBar = Drawing.new("Square") HealthBar.Filled = true HealthBar.Thickness = 1 HealthBar.Visible = false
    local Tracer = Drawing.new("Line") Tracer.Thickness = 2 Tracer.Visible = false
    local Holding = Drawing.new("Text") Holding.Size = 12 Holding.Center = true Holding.Outline = true Holding.Visible = false
   
    table[obj] = {
        Box = Box, Name = Name, HealthBar = HealthBar, Tracer = Tracer, Holding = Holding,
        Color = color, Obj = obj, IsLoot = isLoot or false, PlayerName = playerName
    }
end
local function ApplyChams(character, enabled)
    if not character then return end
    if ChamHighlights[character] then
        ChamHighlights[character].Enabled = enabled
        return
    end
    if enabled then
        local highlight = Instance.new("Highlight")
        highlight.Adornee = character
        highlight.FillColor = Color3.fromRGB(80, 180, 255)
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
        highlight.Parent = character
        ChamHighlights[character] = highlight
    end
end
local function CleanupOldESP(table)
    for obj, data in pairs(table) do
        if not obj or not obj.Parent then
            pcall(function()
                for _, v in pairs(data) do
                    if typeof(v) == "Instance" and v.Remove then v:Remove() end
                end
            end)
            pcall(function()
                if ChamHighlights[obj] then
                    ChamHighlights[obj]:Destroy()
                    ChamHighlights[obj] = nil
                end
            end)
            table[obj] = nil
        end
    end
end
local function IsVisible(target)
    if not target then return false end
    local origin = Cam.CFrame.Position
    local direction = (target.Position - origin).Unit
    local ray = Ray.new(origin, direction * 500)
    local hit, _ = workspace:FindPartOnRayWithIgnoreList(ray, {LP.Character})
    return hit == target or hit == nil
end

local function SetupPlayerCleanup(plr)
    if plr == LP then return end
    plr.CharacterRemoving:Connect(function(char)
        pcall(function()
            if PlayerESPTable[char] then
                local data = PlayerESPTable[char]
                for _, v in pairs(data) do
                    if typeof(v) == "Instance" and v.Remove then v:Remove() end
                end
                PlayerESPTable[char] = nil
            end
        end)
        pcall(function()
            if ChamHighlights[char] then
                ChamHighlights[char]:Destroy()
                ChamHighlights[char] = nil
            end
        end)
    end)
end

for _, plr in pairs(Players:GetPlayers()) do
    SetupPlayerCleanup(plr)
end
