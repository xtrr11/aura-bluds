end)

local function UpdateESP()
    CleanupOldESP(PlayerESPTable)
    CleanupOldESP(LootNPCESPTable)
    
    if Settings.ESP.Players then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LP and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                CreateESP(PlayerESPTable, plr.Character, Color3.fromRGB(180, 80, 255), false, plr.Name)
                ApplyChams(plr.Character, Settings.ESP.Chams)
            end
        end
    end
    
    local now = tick()
    if now - lastLootNPCUpdate > 2 then
        lastLootNPCUpdate = now
        if Settings.NPC.Enabled then
            local npcFolder = FindNPCFolder()
            if npcFolder then
                for _, model in pairs(npcFolder:GetDescendants()) do
                    if model:IsA("Model") and model:FindFirstChild("HumanoidRootPart") then
                        CreateESP(LootNPCESPTable, model, Color3.fromRGB(80, 160, 255), false)
                    end
                end
            end
        end
        if Settings.Loot.Enabled then
            local lootFolder = FindLootFolder()
            if lootFolder then
                for _, item in pairs(lootFolder:GetDescendants()) do
                    if item:IsA("Model") and item.PrimaryPart then
                        local name = item.Name:lower()
                        if name:find("crate") or name:find("case") or name:find("locker") or name:find("box") or name:find("safe") or name:find("loot") or name:find("item") or name:find("chest") then
                            CreateESP(LootNPCESPTable, item, Color3.fromRGB(255, 215, 0), true)
                        end
                    end
                end
            end
        end
    end
end

RS.RenderStepped:Connect(function()
    UpdateESP()
    local center = Vector2.new(Cam.ViewportSize.X/2, Cam.ViewportSize.Y/2)
    local bestTarget = nil
    local bestDist = 9999
    if Settings.VisibleCheck.Enabled then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LP and plr.Character then
                local part = plr.Character:FindFirstChild(Settings.Aimbot.TargetPart) or plr.Character:FindFirstChild("Head")
                if part then
                    local s, on = Cam:WorldToViewportPoint(part.Position)
                    if on then
                        local d = (Vector2.new(s.X, s.Y) - center).Magnitude
                        if d < Settings.Aimbot.FOV and d < bestDist then
                            bestDist = d
                            bestTarget = part
                        end
                    end
                end
            end
        end
    end
    if Settings.VisibleCheck.Enabled then
        if not VisibleBar then
            VisibleBar = Drawing.new("Text")
            VisibleBar.Size = 18
            VisibleBar.Center = true
            VisibleBar.Outline = true
            VisibleBar.Font = 2
        end
        if bestTarget then
            local name = bestTarget.Parent.Name
            local dist = math.floor((Cam.CFrame.Position - bestTarget.Position).Magnitude)
            local visible = IsVisible(bestTarget) and "VISIBLE" or "NOT VISIBLE"
            local color = IsVisible(bestTarget) and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 60, 60)
            VisibleBar.Text = name .. " " .. dist .. "m " .. visible
            VisibleBar.Position = Vector2.new(center.X, center.Y + Settings.Aimbot.FOV + 35)
            VisibleBar.Color = color
            VisibleBar.Visible = true
        else
            VisibleBar.Visible = false
        end
    elseif VisibleBar then
        VisibleBar.Visible = false
    end
    
    -- PLAYER ESP
    for obj, data in pairs(PlayerESPTable) do
        pcall(function()
            if obj and obj.Parent and Settings.ESP.Players then
                local root = obj:FindFirstChild("HumanoidRootPart") or obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                if root then
                    local pos = root.Position
                    local screen, onScreen = Cam:WorldToViewportPoint(pos)
                    local dist = (Cam.CFrame.Position - pos).Magnitude
                    if onScreen and dist <= Settings.ESP.Distance then
                        local height = 3800 / screen.Z
                        local width = height * 0.55
                        data.Box.Size = Vector2.new(width, height)
                        data.Box.Position = Vector2.new(screen.X - width/2, screen.Y - height/2)
                        data.Box.Color = data.Color
                        data.Box.Visible = Settings.ESP.Boxes
                        data.Tracer.From = Vector2.new(Cam.ViewportSize.X/2, Cam.ViewportSize.Y)
                        data.Tracer.To = Vector2.new(screen.X, screen.Y)
                        data.Tracer.Color = data.Color
                        data.Tracer.Visible = Settings.ESP.Tracers
                        if obj:FindFirstChild("Humanoid") then
                            local health = obj.Humanoid.Health / obj.Humanoid.MaxHealth
                            data.HealthBar.Size = Vector2.new(4, height * health)
                            data.HealthBar.Position = Vector2.new(data.Box.Position.X - 6, data.Box.Position.Y + height * (1 - health))
                            data.HealthBar.Color = Color3.fromRGB(255 - 255 * health, 255 * health, 0)
                            data.HealthBar.Visible = Settings.ESP.Health
                        else
                            data.HealthBar.Visible = false
                        end
                        local displayName = data.PlayerName or obj.Name
                        data.Name.Text = displayName .. " [" .. math.floor(dist) .. "m]"
                        data.Name.Position = Vector2.new(screen.X, screen.Y - height/2 + 16)
                        data.Name.Color = data.Color
                        data.Name.Visible = Settings.ESP.Names
                        if data.Holding then
                            local tool = obj:FindFirstChildWhichIsA("Tool")
                            data.Holding.Text = tool and ("Holding: " .. tool.Name) or ""
                            data.Holding.Position = Vector2.new(screen.X, screen.Y + height/2 + 8)
                            data.Holding.Color = Color3.fromRGB(255, 180, 80)
                            data.Holding.Visible = true
                        end
                    else
                        data.Box.Visible = false
                        data.Name.Visible = false
                        data.HealthBar.Visible = false
                        data.Tracer.Visible = false
                        if data.Holding then data.Holding.Visible = false end
                    end
                end
            else
                -- Hide when toggled off
                if data.Box then data.Box.Visible = false end
                if data.Name then data.Name.Visible = false end
                if data.HealthBar then data.HealthBar.Visible = false end
                if data.Tracer then data.Tracer.Visible = false end
                if data.Holding then data.Holding.Visible = false end
            end
        end)
    end
    
    -- LOOT / NPC ESP
    if Settings.Loot.Enabled or Settings.NPC.Enabled then
        for obj, data in pairs(LootNPCESPTable) do
            pcall(function()
                if obj and obj.Parent then
                    local root = obj.PrimaryPart or obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChildWhichIsA("BasePart")
                    if root then
                        local pos = root.Position
                        local screen, onScreen = Cam:WorldToViewportPoint(pos)
                        local dist = (Cam.CFrame.Position - pos).Magnitude
                        local maxDist = data.IsLoot and Settings.Loot.Distance or Settings.NPC.Distance
                        local show = data.IsLoot and Settings.Loot.Enabled or (not data.IsLoot and Settings.NPC.Enabled)
                        if onScreen and dist <= maxDist and show then
                            local displayName = obj.Name
                            data.Name.Text = displayName .. " [" .. math.floor(dist) .. "m]"
                            data.Name.Position = Vector2.new(screen.X, screen.Y - 15)
                            data.Name.Color = data.Color
                            data.Name.Visible = Settings.ESP.Names
                        else
                            data.Name.Visible = false
                        end
                    end
                end
            end)
        end
    end
    
    if Settings.Aimbot.ShowFOV then
        if not FOVCircle then
            FOVCircle = Drawing.new("Circle")
            FOVCircle.Thickness = 2
            FOVCircle.Filled = false
            FOVCircle.Color = Color3.fromRGB(255, 80, 120)
        end
        FOVCircle.Position = center
        FOVCircle.Radius = Settings.Aimbot.FOV
        FOVCircle.Visible = true
    elseif FOVCircle then
        FOVCircle.Visible = false
    end
    if Settings.Aimbot.Enabled and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local closest, minDist = nil, Settings.Aimbot.FOV
        local centerVec = Vector2.new(Cam.ViewportSize.X/2, Cam.ViewportSize.Y/2)
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LP and plr.Character then
                local part = plr.Character:FindFirstChild(Settings.Aimbot.TargetPart) or plr.Character:FindFirstChild("Head")
                if part then
                    local s, on = Cam:WorldToViewportPoint(part.Position)
                    if on then
                        local d = (Vector2.new(s.X, s.Y) - centerVec).Magnitude
                        if d < minDist then
                            minDist = d
                            closest = part
                        end
                    end
                end
            end
        end
        if closest then
            local targetPos = Cam:WorldToScreenPoint(closest.Position)
            local mousePos = Vector2.new(Mouse.X, Mouse.Y)
            local moveX = (targetPos.X - mousePos.X) / Settings.Aimbot.Smooth
            local moveY = (targetPos.Y - mousePos.Y) / Settings.Aimbot.Smooth
            mousemoverel(moveX, moveY)
        end
    end
end)
