    local function ShowInventory(plr)
        if not plr or not plr.Character then 
            InvFrame.Visible = false 
            return 
        end
        PlayerNameLabel.Text = "Viewing: " .. plr.Name

        local character = plr.Character
        local backpack = plr:FindFirstChild("Backpack")

        local armorItems = {}
        if character then
            for _, item in ipairs(character:GetChildren()) do
                if item:IsA("Accessory") or string.find(item.Name:lower(), "helmet") or string.find(item.Name:lower(), "vest") or string.find(item.Name:lower(), "armor") then
                    table.insert(armorItems, "• " .. item.Name)
                end
            end
        end
        ArmorList.Text = #armorItems > 0 and table.concat(armorItems, "\n") or "No Armor"

        local hotbarItems = {}
        if character then
            for _, item in ipairs(character:GetChildren()) do
                if item:IsA("Tool") then
                    table.insert(hotbarItems, "• " .. item.Name)
                end
            end
        end
        HotbarList.Text = #hotbarItems > 0 and table.concat(hotbarItems, "\n") or "Empty"

        local fullItems = {}
        if backpack then
            for _, item in ipairs(backpack:GetChildren()) do
                if item:IsA("Tool") or item:IsA("HopperBin") then
                    table.insert(fullItems, "• " .. item.Name)
                end
            end
        end
        FullList.Text = #fullItems > 0 and table.concat(fullItems, "\n") or "Empty"

        InvFrame.Visible = true
    end

    RS.RenderStepped:Connect(function()
        local center = Vector2.new(Cam.ViewportSize.X/2, Cam.ViewportSize.Y/2)

        AimCircle.Position = center
        AimCircle.Radius = Settings.Aimbot.FOV
        AimCircle.Visible = Settings.Aimbot.ShowFOV

        for plr, data in pairs(ESPTable) do
            local char = plr.Character
            if char and char:FindFirstChild("Head") and char:FindFirstChild("HumanoidRootPart") then
                local root = char.HumanoidRootPart
                local head = char.Head
                local rPos = Cam:WorldToViewportPoint(root.Position)
                local hPos = Cam:WorldToViewportPoint(head.Position)

                if rPos.Z > 0 then
                    local vis = IsVisible(head)
                    local color = vis and Color3.fromRGB(0,255,100) or Color3.fromRGB(255,50,50)

                    local height = (rPos.Y - hPos.Y) * 2.6
                    local width = height * 0.5

                    data.Box.Size = Vector2.new(width, height)
                    data.Box.Position = Vector2.new(rPos.X - width/2, hPos.Y - height*0.15)
                    data.Box.Color = color
                    data.Box.Visible = Settings.ESP.Boxes

                    local dist = math.floor((Cam.CFrame.Position - root.Position).Magnitude)
                    data.Name.Text = plr.Name .. " ["..dist.."m]"
                    data.Name.Position = Vector2.new(rPos.X, hPos.Y - height*0.45)
                    data.Name.Color = color
                    data.Name.Visible = Settings.ESP.Names
                else
                    data.Box.Visible = false
                    data.Name.Visible = false
                end
            else
                data.Box.Visible = false
                data.Name.Visible = false
            end
        end

        if Settings.Exploits.ShowInventory then
            local closest = nil
            local minDist = math.huge
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LP and plr.Character and plr.Character:FindFirstChild("Head") then
                    local head = plr.Character.Head
                    local screen, onScreen = Cam:WorldToViewportPoint(head.Position)
                    if onScreen then
                        local d = (Vector2.new(screen.X, screen.Y) - center).Magnitude
                        if d <= Settings.Aimbot.FOV and d < minDist then
                            minDist = d
                            closest = plr
                        end
                    end
                end
            end
            if closest then ShowInventory(closest) else InvFrame.Visible = false end
        else
            InvFrame.Visible = false
        end

        local closestAim = GetClosest()
        if closestAim then
            local vis = IsVisible(closestAim.Part)
            local text = closestAim.Player.Name .. (vis and " VISIBLE" or " NONVISIBLE")
            local color = vis and Color3.fromRGB(0,255,100) or Color3.fromRGB(255,100,100)

            StatusText.Text = text
            StatusText.Color = color
            StatusText.Position = Vector2.new(center.X, center.Y + Settings.Aimbot.FOV + 40)
            StatusText.Visible = true

            StatusBar.Size = Vector2.new(StatusText.TextBounds.X + 20, 28)
            StatusBar.Position = Vector2.new(center.X - StatusBar.Size.X/2, center.Y + Settings.Aimbot.FOV + 32)
            StatusBar.Visible = true
        else
            StatusText.Visible = false
            StatusBar.Visible = false
        end

        if Settings.Aimbot.Enabled and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            local t = GetClosest()
            if t and t.Part then
                Cam.CFrame = Cam.CFrame:Lerp(CFrame.lookAt(Cam.CFrame.Position, t.Part.Position), 1/Settings.Aimbot.Smooth)
            end
        end
    end)

