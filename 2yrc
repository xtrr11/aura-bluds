            StatusText.Color = color
            StatusText.Position = Vector2.new(center.X, center.Y + Settings.Aimbot.FOV + 40)
            StatusText.Visible = true

            StatusBar.Size = Vector2.new(StatusText.TextBounds.X + 20, 28)
            StatusBar.Position = Vector2.new(center.X - StatusBar.Size.X/2, center.Y + Settings.Aimbot.FOV + 32)
            StatusBar.Visible = true
        else
            StatusText.Visible = false
            StatusBar.Visible = false
        end

        if Settings.Aimbot.Enabled and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            local t = GetClosest()
            if t and t.Part then
                Cam.CFrame = Cam.CFrame:Lerp(CFrame.lookAt(Cam.CFrame.Position, t.Part.Position), 1/Settings.Aimbot.Smooth)
            end
        end
    end)

