        AimCircle.Radius = Settings.Aimbot.FOV
        AimCircle.Visible = Settings.Aimbot.ShowFOV
        AimCircle.Color = Settings.Aimbot.FOVColor

        for plr, data in pairs(ESPTable) do
            local char = plr.Character
            if char and char:FindFirstChild("Head") and char:FindFirstChild("HumanoidRootPart") then
                local root = char.HumanoidRootPart
                local head = char.Head
                local rPos = Cam:WorldToViewportPoint(root.Position)
                local hPos = Cam:WorldToViewportPoint(head.Position)

                if rPos.Z > 0 then
                    local vis = IsVisible(head)
                    local color = vis and Settings.ESP.BoxColorVisible or Settings.ESP.BoxColorHidden

                    local height = (rPos.Y - hPos.Y) * 2.6
                    local width = height * 0.5

                    data.Box.Size = Vector2.new(width, height)
                    data.Box.Position = Vector2.new(rPos.X - width/2, hPos.Y - height*0.15)
                    data.Box.Color = color
                    data.Box.Visible = Settings.ESP.Boxes

                    local dist = math.floor((Cam.CFrame.Position - root.Position).Magnitude)
                    data.Name.Text = plr.Name .. " ["..dist.."m]"
                    data.Name.Position = Vector2.new(rPos.X, hPos.Y - height*0.45)
                    data.Name.Color = color
                    data.Name.Visible = Settings.ESP.Names

                    -- PERFECT SKELETON
                    if Settings.ESP.Skeleton then
                        local function DrawLine(from, to)
                            local line = Drawing.new("Line")
                            line.Thickness = 1.5
                            line.Color = color
                            line.Transparency = 1
                            line.From = from
                            line.To = to
                            return line
                        end

                        local p = {}
                        if char:FindFirstChild("Head") then p.Head = Cam:WorldToViewportPoint(char.Head.Position) end
                        if char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso") then p.Torso = Cam:WorldToViewportPoint((char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")).Position) end
                        if char:FindFirstChild("LeftUpperArm") then p.LUA = Cam:WorldToViewportPoint(char.LeftUpperArm.Position) end
                        if char:FindFirstChild("RightUpperArm") then p.RUA = Cam:WorldToViewportPoint(char.RightUpperArm.Position) end
                        if char:FindFirstChild("LeftLowerArm") then p.LLA = Cam:WorldToViewportPoint(char.LeftLowerArm.Position) end
                        if char:FindFirstChild("RightLowerArm") then p.RLA = Cam:WorldToViewportPoint(char.RightLowerArm.Position) end
                        if char:FindFirstChild("LeftUpperLeg") then p.LUL = Cam:WorldToViewportPoint(char.LeftUpperLeg.Position) end
                        if char:FindFirstChild("RightUpperLeg") then p.RUL = Cam:WorldToViewportPoint(char.RightUpperLeg.Position) end
                        if char:FindFirstChild("LeftLowerLeg") then p.LLL = Cam:WorldToViewportPoint(char.LeftLowerLeg.Position) end
                        if char:FindFirstChild("RightLowerLeg") then p.RLL = Cam:WorldToViewportPoint(char.RightLowerLeg.Position) end

                        if p.Head and p.Torso then DrawLine(Vector2.new(p.Head.X, p.Head.Y), Vector2.new(p.Torso.X, p.Torso.Y)) end
                        if p.Torso then
                            if p.LUA then DrawLine(Vector2.new(p.Torso.X, p.Torso.Y), Vector2.new(p.LUA.X, p.LUA.Y)) end
                            if p.RUA then DrawLine(Vector2.new(p.Torso.X, p.Torso.Y), Vector2.new(p.RUA.X, p.RUA.Y)) end
                            if p.LUL then DrawLine(Vector2.new(p.Torso.X, p.Torso.Y), Vector2.new(p.LUL.X, p.LUL.Y)) end
                            if p.RUL then DrawLine(Vector2.new(p.Torso.X, p.Torso.Y), Vector2.new(p.RUL.X, p.RUL.Y)) end
                        end
                        if p.LUA and p.LLA then DrawLine(Vector2.new(p.LUA.X, p.LUA.Y), Vector2.new(p.LLA.X, p.LLA.Y)) end
                        if p.RUA and p.RLA then DrawLine(Vector2.new(p.RUA.X, p.RUA.Y), Vector2.new(p.RLA.X, p.RLA.Y)) end
                        if p.LUL and p.LLL then DrawLine(Vector2.new(p.LUL.X, p.LUL.Y), Vector2.new(p.LLL.X, p.LLL.Y)) end
                        if p.RUL and p.RLL then DrawLine(Vector2.new(p.RUL.X, p.RUL.Y), Vector2.new(p.RLL.X, p.RLL.Y)) end
                    end

                    -- CAUTION
                    local lookingAtYou = false
                    if char:FindFirstChild("Head") then
                        local headDir = (Cam.CFrame.Position - char.Head.Position).Unit
                        local playerLookDir = char.Head.CFrame.LookVector
                        if headDir:Dot(playerLookDir) > 0.8 then
                            lookingAtYou = true
                        end
                    end

                    if lookingAtYou and Settings.ESP.Caution then
                        data.Caution.Text = "CAUTION"
                        data.Caution.Position = Vector2.new(rPos.X, hPos.Y - height*0.9)
                        data.Caution.Visible = true
                    else
                        data.Caution.Visible = false
                    end
                else
                    data.Box.Visible = false
                    data.Name.Visible = false
                    data.Caution.Visible = false
                end
            else
                data.Box.Visible = false
                data.Name.Visible = false
                data.Caution.Visible = false
            end
        end

        if Settings.Exploits.ShowInventory then
            local closest = nil
            local minDist = math.huge
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LP and plr.Character and plr.Character:FindFirstChild("Head") then
                    local head = plr.Character.Head
                    local screen, onScreen = Cam:WorldToViewportPoint(head.Position)
                    if onScreen then
                        local d = (Vector2.new(screen.X, screen.Y) - center).Magnitude
                        if d <= Settings.Aimbot.FOV and d < minDist then
                            minDist = d
                            closest = plr
                        end
                    end
                end
            end
            if closest then ShowInventory(closest) else InvFrame.Visible = false end
        else
            InvFrame.Visible = false
        end

        local closestAim = GetClosest()
        if closestAim then
            local vis = IsVisible(closestAim.Part)
            local text = closestAim.Player.Name .. (vis and " VISIBLE" or " NONVISIBLE")
            local color = vis and Color3.fromRGB(0,255,100) or Color3.fromRGB(255,100,100)

